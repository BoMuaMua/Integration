<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.permission.mapper.ActivityMapper">

    <insert id="addActivity" parameterType="com.example.permission.entity.Participants">
        INSERT INTO User_Fraction(user_id, activity_id)
        VALUES
        <foreach collection="participants" item="item" separator=",">
            (#{item.id}, #{activity.activityId})
        </foreach>
    </insert>
    <insert id="addPeople" parameterType="com.example.permission.entity.AddPeople">
        INSERT INTO User_Fraction(user_id, activity_id)
        VALUES
        <foreach collection="userId" item="item" separator=",">
            (#{item}, #{activityId})
        </foreach>
    </insert>
    <insert id="bindingIndicators" parameterType="com.example.permission.entity.ActivityIndicators">
        INSERT INTO Indicators_Activity(activity_id, indicators_id)
        VALUES
        <foreach collection="indicatorsId" item="item" separator=",">
            (#{activityId}, #{item})
        </foreach>
    </insert>

    <!-- 删除活动与参与者的关联 -->
    <delete id="deleteActivityAssociation">
        DELETE FROM User_Fraction WHERE activity_id = #{activityId}
    </delete>
    <delete id="deletePeople" parameterType="map">
        DELETE FROM User_Fraction
        WHERE activity_id = #{activityId}
        AND user_id IN
        <foreach collection="userIdList" item="userId" open="(" close=")" separator=",">
            #{userId}
        </foreach>
    </delete>
    <delete id="deleteBinding">
        DELETE FROM Indicators_Activity
        WHERE activity_id = #{activityId}
        AND indicators_id = #{indicatorsId}
    </delete>
    <delete id="deleteActivityIndicators" parameterType="java.lang.Integer">
        DELETE FROM Indicators_Activity
        WHERE activity_id = #{activityId}
    </delete>
</mapper>